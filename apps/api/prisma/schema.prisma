generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CONTADOR
  VIEWER
}

enum TaxRegime {
  ORDINARIO
  RST
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NcfType {
  B01
  B02
  B14
  B15
  B16
  E31
  E32
  E33
  E34
  E41
  E43
  E44
  E45
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  companyRoles UserCompanyRole[]
}

model Company {
  id             String            @id @default(cuid())
  name           String
  rnc            String            @unique
  tradeName      String?
  taxRegime      TaxRegime         @default(ORDINARIO)
  address        String?
  phone          String?
  email          String?
  lockDate       DateTime?         @db.Date
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  userRoles      UserCompanyRole[]
  accounts       Account[]
  journalEntries JournalEntry[]
  ncfSequences   NcfSequence[]
  expenses       Expense[]
  invoices       Invoice[]
  contacts       Contact[]
  employees      Employee[]
  payrolls       Payroll[]
  bankTransactions BankTransaction[]
  taxFilings     TaxFiling[]
}

model UserCompanyRole {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Account {
  id         String             @id @default(cuid())
  companyId  String
  code       String
  name       String
  type       AccountType
  parentId   String?
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent     Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children   Account[]          @relation("AccountHierarchy")
  entryLines JournalEntryLine[]
  bankTransactions BankTransaction[]

  @@unique([companyId, code])
}

model JournalEntry {
  id          String             @id @default(cuid())
  companyId   String
  date        DateTime           @db.Date
  description String
  reference   String?
  status      JournalEntryStatus @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       JournalEntryLine[]
  expense     Expense?
  invoice     Invoice?
  payrolls    Payroll[]

  @@index([companyId, status])
  @@index([companyId, date])
}

model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  clientRnc      String
  clientName     String
  ncf            String
  ncfType        NcfType
  date           DateTime      @db.Date
  paymentDate    DateTime?     @db.Date
  amount         Decimal       @db.Decimal(18, 2)
  itbis          Decimal       @default(0) @db.Decimal(18, 2)
  paymentMethod  String
  journalEntryId String?       @unique
  isVoided       Boolean       @default(false)
  itbisRetained  Decimal       @default(0) @db.Decimal(18, 2)
  isrRetained    Decimal       @default(0) @db.Decimal(18, 2)
  costOfGoodsSold Decimal?     @db.Decimal(18, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([companyId, date])
  @@index([companyId, isVoided, date])
}

model Expense {
  id             String        @id @default(cuid())
  companyId      String
  providerRnc    String
  providerName   String
  ncf            String
  expenseType    String
  date           DateTime      @db.Date
  paymentDate    DateTime?     @db.Date
  amount         Decimal       @db.Decimal(18, 2)
  itbis          Decimal       @default(0) @db.Decimal(18, 2)
  itbisRetained  Decimal       @default(0) @db.Decimal(18, 2)
  isrRetained    Decimal       @default(0) @db.Decimal(18, 2)
  paymentMethod  String
  journalEntryId String?       @unique
  isVoided       Boolean       @default(false)
  isForeignPayment Boolean     @default(false)
  foreignCountry   String?
  foreignTaxId     String?
  foreignPaymentType String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([companyId, date])
  @@index([companyId, isVoided, date])
  @@index([companyId, isForeignPayment])
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(18, 2)
  credit         Decimal      @default(0) @db.Decimal(18, 2)
  description    String?
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])
  bankTransactions BankTransaction[]

  @@index([journalEntryId])
  @@index([accountId])
}

model NcfSequence {
  id        String   @id @default(cuid())
  companyId String
  type      NcfType
  prefix    String
  current   Int      @default(0)
  max       Int
  isActive  Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
}

enum ContactType {
  CLIENT
  PROVIDER
  BOTH
}

model Contact {
  id        String      @id @default(cuid())
  companyId String
  rnc       String
  name      String
  type      ContactType @default(CLIENT)
  email     String?
  phone     String?
  address   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, rnc])
}

model Employee {
  id           String        @id @default(cuid())
  companyId    String
  cedula       String
  name         String
  salary       Decimal       @db.Decimal(18, 2)
  jobTitle     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollItems PayrollItem[]

  @@unique([companyId, cedula])
}

model Payroll {
  id             String        @id @default(cuid())
  companyId      String
  period         String // Format: YYYYMM (e.g., "202607")
  grossSalary    Decimal       @db.Decimal(18, 2)
  sfsEmployee    Decimal       @db.Decimal(18, 2)
  sfsEmployer    Decimal       @db.Decimal(18, 2)
  afpEmployee    Decimal       @db.Decimal(18, 2)
  afpEmployer    Decimal       @db.Decimal(18, 2)
  arlEmployer    Decimal       @db.Decimal(18, 2)
  isrDeduction   Decimal       @db.Decimal(18, 2)
  netSalary      Decimal       @db.Decimal(18, 2)
  journalEntryId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  items          PayrollItem[]

  @@unique([companyId, period])
}

model PayrollItem {
  id           String   @id @default(cuid())
  payrollId    String
  employeeId   String
  grossSalary  Decimal  @db.Decimal(18, 2)
  sfsEmployee  Decimal  @db.Decimal(18, 2)
  afpEmployee  Decimal  @db.Decimal(18, 2)
  isrDeduction Decimal  @db.Decimal(18, 2)
  netSalary    Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  payroll      Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id])
}

model BankTransaction {
  id                  String            @id @default(cuid())
  companyId           String
  accountId           String
  date                DateTime
  description         String
  amount              Decimal           @db.Decimal(18, 2)
  reference           String?
  reconciled          Boolean           @default(false)
  journalEntryLineId  String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  company             Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account             Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  journalEntryLine    JournalEntryLine? @relation(fields: [journalEntryLineId], references: [id])

  @@index([companyId, accountId, reconciled])
  @@index([companyId, accountId, date])
}

model TaxFiling {
  id              String    @id @default(cuid())
  companyId       String
  period          String    // Formato: AAAAMM (ej: 202607)
  taxType         String    // ej: 'IT1'
  salesAmount     Decimal   @db.Decimal(18, 2)
  salesItbis      Decimal   @db.Decimal(18, 2)
  purchasesAmount Decimal   @db.Decimal(18, 2)
  purchasesItbis  Decimal   @db.Decimal(18, 2)
  itbisToPay      Decimal   @db.Decimal(18, 2)
  status          String    @default("FILED")
  filedAt         DateTime  @default(now())
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, period, taxType])
}
